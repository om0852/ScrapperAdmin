PORT=7000
NODE_ENV=production
LOG_LEVEL=info

# MongoDB URI - Set this in XtraSecurity secrets
# Format: mongodb+srv://username:password@host/database
# This will be automatically injected by XtraSecurity when running: xtra run npm start
MONGODB_URI=mongodb+srv://user:password@your-cluster.mongodb.net/quickcommerce

# Optional: Add other platform-specific API keys or secrets here
# All secrets should be added via: xtra secret set SECRET_NAME "value"
